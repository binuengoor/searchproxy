# --- Core: API Authentication ---
# Set to true to require Bearer token on all endpoints (except /health, /docs)
SEARCHPROXY_REQUIRE_AUTH=false
SEARCHPROXY_API_KEY=change-me-in-production

# --- Search (LiteLLM) ---
# If LiteLLM runs on the Docker host, use host.docker.internal
# If LiteLLM runs in another compose, use its service name
LITELLM_SEARCH_URL=http://host.docker.internal:4000/search/unifiedsearch
LITELLM_API_KEY=

# --- Retrieve: LiteLLM Chat (synthesis) ---
LITELLM_CHAT_URL=http://host.docker.internal:4000/v1/chat/completions
LITELLM_CHAT_MODEL=openai/gpt-4o-mini

# --- Retrieve: BGE Reranker (cf-inference) ---
CF_RERANK_URL=https://cf-inference.binuengoor.workers.dev/v1/rerank
CF_RERANK_API_KEY=
CF_RERANK_MODEL=@cf/baai/bge-reranker-base

# --- Retrieve: tuning ---
RETRIEVE_MAX_CONTENT_PER_SOURCE=6000
RETRIEVE_MAX_TOTAL_CONTENT=12000
RETRIEVE_RERANK_TOP_K=20
RETRIEVE_MIN_CONTENT_LENGTH=300
RETRIEVE_FETCH_TIMEOUT=15
RETRIEVE_PREFETCH_DURING_RERANK=true
RETRIEVE_PREFETCH_MAX=3
SYNTHESIS_MAX_TOKENS=2048
SYNTHESIS_TIMEOUT=60
RERANK_TIMEOUT=10

# --- Research (Vane) ---
VANE_URL=http://host.docker.internal:3001
VANE_CHAT_PROVIDER_ID=
VANE_CHAT_MODEL_KEY=
VANE_EMBED_PROVIDER_ID=
VANE_EMBED_MODEL_KEY=

# --- Compat: SearXNG passthrough ---
SEARXNG_URL=http://host.docker.internal:8980/search

# --- Fetch: Crawl4AI (separate compose) ---
# Crawl4AI runs in a separate compose on the Docker host
CRAWL4AI_URL=http://host.docker.internal:11235
# Optional: LLM config for Crawl4AI structured extraction
CRAWL4AI_LLM_PROVIDER=
CRAWL4AI_LLM_BASE_URL=
CRAWL4AI_LLM_API_KEY=

# --- Fetch: Jina Reader ---
JINA_API_KEY=

# --- Fetch: Anti-bot specialists ---
SCRAPE_DO_API_KEY=
SCRAPERAPI_API_KEY=

# --- Timeouts ---
FETCH_TIMEOUT=30        # generic fallback; per-tier overrides below
SEARCH_TIMEOUT=15
VANE_TIMEOUT=120
CRAWL4AI_TIMEOUT=15
JINA_TIMEOUT=15
ANTIBOT_TIMEOUT=45
CONNECT_TIMEOUT=5       # shared connect timeout for all downstream HTTP clients

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=text  # text or json

# --- Observability ---
OBSERVABILITY_ENABLED=true
OBSERVABILITY_DB_PATH=/data/observability.db
OBSERVABILITY_RETENTION_DAYS=7

# --- Caching ---
CACHE_ENABLED=false          # Set to true to enable SQLite caching for search and fetch results.
CACHE_SEARCH_TTL=300         # TTL for search cache entries in seconds.
CACHE_FETCH_TTL=86400        # TTL for fetch cache entries in seconds.
CACHE_RERANK_TTL=300         # TTL for rerank cache entries in seconds.
CACHE_DB_PATH=/data/cache.db # Path to SQLite cache database (mounted volume).