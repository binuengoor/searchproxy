# --- Core: API Authentication ---
# Set to true to require Bearer token on all endpoints (except /health, /docs)
SEARCHPROXY_REQUIRE_AUTH=false
SEARCHPROXY_API_KEY=change-me-in-production

# --- Search (LiteLLM) ---
# If LiteLLM runs on the Docker host, use host.docker.internal
# If LiteLLM runs in another compose, use its service name
LITELLM_SEARCH_URL=http://host.docker.internal:4000/search/unifiedsearch
LITELLM_API_KEY=

# --- Research (Vane) ---
VANE_URL=http://host.docker.internal:3001
VANE_CHAT_PROVIDER_ID=
VANE_CHAT_MODEL_KEY=
VANE_EMBED_PROVIDER_ID=
VANE_EMBED_MODEL_KEY=

# --- Compat: SearXNG passthrough ---
SEARXNG_URL=http://host.docker.internal:8980/search

# --- Fetch: Crawl4AI (separate compose) ---
# Crawl4AI runs in a separate compose on the Docker host
CRAWL4AI_URL=http://host.docker.internal:11235
# Optional: LLM config for Crawl4AI structured extraction
CRAWL4AI_LLM_PROVIDER=
CRAWL4AI_LLM_BASE_URL=
CRAWL4AI_LLM_API_KEY=

# --- Fetch: Jina Reader ---
JINA_API_KEY=

# --- Fetch: Anti-bot specialists ---
SCRAPE_DO_API_KEY=
SCRAPERAPI_API_KEY=

# --- Timeouts ---
FETCH_TIMEOUT=30
SEARCH_TIMEOUT=15
VANE_TIMEOUT=120

# --- Logging ---
LOG_LEVEL=INFO
